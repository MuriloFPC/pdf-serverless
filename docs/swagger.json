    "definitions": {
        "entities.FileMetadata": {
            "type": "object",
            "properties": {
                "filename": {
                    "type": "string"
                },
                "page_count": {
                    "type": "integer"
                },
                "path": {
                    "type": "string"
                },
                "size_kb": {
                    "type": "number"
                },
                "uploaded_at": {
                    "type": "string"
                }
            }
        },
        "entities.JobStatus": {
            "type": "string",
            "enum": [
                "awaiting_files",
                "pending",
                "processing",
                "completed",
                "failed",
                "manually_excluded",
                "automatically_excluded"
            ],
            "x-enum-varnames": [
                "StatusAwaitingFiles",
                "StatusPending",
                "StatusProcessing",
                "StatusCompleted",
                "StatusFailed",
                "StatusManuallyExcluded",
                "StatusAutomaticallyExcluded"
            ]
        },
        "entities.PDFJob": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "delete_at": {
                    "type": "string"
                },
                "deleted_at": {
                    "type": "string"
                },
                "input_files": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/entities.FileMetadata"
                    }
                },
                "job_id": {
                    "type": "string"
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "output_files": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/entities.FileMetadata"
                    }
                },
                "password": {
                    "type": "string"
                },
                "process_type": {
                    "$ref": "#/definitions/entities.ProcessType"
                },
                "status": {
                    "$ref": "#/definitions/entities.JobStatus"
                },
                "ttl": {
                    "$ref": "#/definitions/entities.TTLType"
                },
                "user_id": {
                    "type": "string"
                }
            }
        },
        "entities.ProcessType": {
            "type": "string",
            "enum": [
                "merge",
                "split",
                "protect",
                "remove_password",
                "optimize"
            ],
            "x-enum-varnames": [
                "TypeMerge",
                "TypeSplit",
                "TypeProtect",
                "TypeRemovePassword",
                "TypeOptimize"
            ]
        },
        "entities.TTLType": {
            "type": "string",
            "enum": [
                "24h",
                "72h",
                "1week",
                "1month",
                "3month",
                "6month",
                "1year",
                "3years",
                "5years",
                "10years",
                "unlimited"
            ],
            "x-enum-varnames": [
                "TTL24h",
                "TTL72h",
                "TTL1Week",
                "TTL1Month",
                "TTL3Month",
                "TTL6Month",
                "TTL1Year",
                "TTL3Year",
                "TTL5Year",
                "TTL10Year",
                "TTLForever"
            ]
        },
        "router.LoginRequest": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "router.ProcessRequest": {
            "type": "object",
            "properties": {
                "metadata": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "password": {
                    "type": "string"
                },
                "ttl": {
                    "$ref": "#/definitions/entities.TTLType"
                },
                "type": {
                    "$ref": "#/definitions/entities.ProcessType"
                }
            }
        },
        "router.RegisterRequest": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}